<div class="row justify-content-center">
  <div class="col-lg-5 col-md-7">
    <div class="card shadow">
      <div class="card-body p-4">
        <h4 class="mb-3 text-center">Login</h4>

        <div class="alert alert-danger d-none" id="login-error"></div>
        <div class="alert alert-info d-none" id="login-info"></div>

        <form id="form-login">
          <div class="form-group">
            <label>Username</label>
            <input type="text" class="form-control" id="login-username" autocomplete="username" required>
          </div>

          <div class="form-group" id="group-password">
            <label>Password</label>
            <input type="password" class="form-control" id="login-password" autocomplete="current-password" required>
          </div>

          <div class="form-group d-none" id="group-2fa">
            <label>Kode Google Authenticator</label>
            <input type="text" class="form-control" id="login-2fa-code" inputmode="numeric" placeholder="6 digit" maxlength="6">
            <small class="form-text text-muted">Buka Google Authenticator, lalu masukkan kode 6 digit.</small>
          </div>

          <button type="submit" class="btn btn-primary btn-block" id="btn-login">Masuk</button>
        </form>

        <hr>
        <div class="text-center small text-muted">
          Sistem Kuisioner Pelatihan
        </div>
      </div>
    </div>
  </div>
</div>
