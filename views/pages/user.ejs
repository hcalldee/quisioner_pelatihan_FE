<h1 class="h3 mb-4 text-gray-800">User</h1>

<div class="card shadow mb-4">
  <div class="card-header py-3 d-flex justify-content-between align-items-center">
    <h6 class="m-0 font-weight-bold text-primary" id="content-title-user"></h6>

    <button class="btn btn-sm btn-primary" id="tbh-data-user">
      <i class="fas fa-plus"></i> Tambah Data
    </button>
  </div>

  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-bordered" id="table-data-user"></table>
    </div>
  </div>
</div>

<div class="modal fade" id="modal-data-user" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="modalTitleUser">Tambah Data User</h5>
        <button type="button" class="close" data-dismiss="modal">
          <span>&times;</span>
        </button>
      </div>

      <div class="modal-body" id="modalBodyUser"></div>

      <div class="modal-footer">
        <button type="button" class="btn btn-primary" id="btn-save-user">Simpan</button>
      </div>

    </div>
  </div>
</div>

